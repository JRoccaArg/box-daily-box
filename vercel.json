{
  "redirects": [
    {
      "source": "/:path*",
      "destination": "https://www.boxdailybox.com/:path*",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "boxdailybox.com"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
